# Copy to .env and fill in values. Do not commit .env.

REDIS_URL=redis://localhost:6379
LITELLM_PRIMARY_MODEL=groq/llama-3.1-8b-instant
LITELLM_FALLBACK_MODEL=gemini/gemini-2.0-flash

GROQ_API_KEY=
GOOGLE_API_KEY=

# YouTube Data API v3 (comma-separated or YOUTUBE_API_KEY_1, _2, _3)
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=

# Instagram session usernames (up to 4); create sessions with: instaloader -l USERNAME
INSTAGRAM_SESSION_USERS=
