# App
PORT=8080

# Postgres
DATABASE_URL=postgres://<db_user>:<db_password>@<db_host>:5432/<db_name>?sslmode=disable

# Redis
REDIS_ADDR=<redis_host>:6379

# Agent service
AGENT_BASE_URL=http://localhost:8000

# Firebase Admin SDK service account JSON path
FIREBASE_CREDENTIALS_PATH=./secret/firebase-service-account.json
